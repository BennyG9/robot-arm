{
    "metadata": {
        "version": 1,

        "name": "robot_arm_communication_protocol",

        "description": "bidirectional communication between STM32 and Jetson Nano"
    },

    "framing": {
        "start_byte": "0xAA",

        "endianness": "little",

        "float": "IEEE754",

        "checksum": "xor",

        "packet": "START | CMD | ARGS | CHECKSUM"
    },

    "commands": {
        "JOINT_STATE": {
            "id": 1,
            "args": [
                {"name": "joint_positions", "type": "float", "count": 4}
            ],
            "direction": "STM32_TO_JETSON",
            "description": "broadcast the current state of each joint",
            "name": "JOINT_STATE"
        },

        "SET_POSITION": {
            "id": 2,
            "args": [
                {"name": "joint_positions", "type": "float", "count": 4}
            ],
            "direction": "JETSON_TO_STM32",
            "description": "set the target positions for each joint",
            "name": "SET_POSITION"
        },

        "CALIBRATE": {
            "id": 3,
            "args": [],
            "direction": "JETSON_TO_STM32",
            "description": "run calibration routine for each joint",
            "name": "CALIBRATE"
        },

        "HOME": {
            "id": 4,
            "args": [],
            "direction": "JETSON_TO_STM32",
            "description": "set each joint to its home position",
            "name": "HOME"
        },

        "SET_PID": {
            "id": 5,
            "args": [
                {"name": "joint_id", "type": "uint8_t", "count": 1},
                {"name": "parameters", "type": "float", "count": 3}
            ],
            "direction": "JETSON_TO_STM32",
            "description": "update PID parameters for a specific joint",
            "name": "SET_PID"
        },

        "ESTOP": {
            "id": 6,
            "args": [],
            "direction": "JETSON_TO_STM32",
            "description": "stop all motion of the robot",
            "name": "ESTOP"
        },

        "ERROR_MSG": {
            "id": 7,
            "args": [
                {"name": "error_code", "type": "uint8_t", "count": 1}
            ],
            "direction": "BIDIRECTIONAL",
            "description": "report error codes",
            "name": "ERROR_MSG"
        }
    }
}
